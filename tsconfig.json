{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/test-utils/*": ["./test-utils/*"]
    },
    "types": ["node"]
  },
  "include": [
    "branding.d.ts",
    "electron/**/*.ts",
    "electron.vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test-utils/**/*.ts",
    "test-utils/**/*.tsx"
  ],
  "exclude": ["out", "dist", "node_modules"],
  "_deferredFlags": "noUnusedParameters (3 violations), noUnusedLocals (13 violations, mostly _-prefixed which ESLint already allows), noUncheckedIndexedAccess (362 violations across renderer code) — to be addressed in follow-up PRs."
}
