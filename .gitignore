node_modules/
out/
dist/
build/bin/
*.map
.DS_Store
.env
.env.*
!.env.example
.claude/settings.json
pnpm-debug.log*
pnpm-lock.yaml
.npmrc
*.tsbuildinfo

# Debug logs written during development (see CLAUDE.md § Debug Logging)
debug-logs/

# Python bytecode (electron/platform/linux/atspi_helper.py)
__pycache__/
*.pyc

# Local branding overrides (developer-specific, not committed)
branding.config.local.ts

# Auto-generated from electron-builder.template.yml by scripts/generate-builder-config.ts
electron-builder.yml

# Bundled plugins are copied in by branded build scripts (e.g. kai-builder/scripts/dev.sh)
bundled-plugins/*/
!bundled-plugins/microsoft-teams/
!bundled-plugins/microsoft-teams/**

# Playwright IPC seam smoke artifacts (see TESTING.md)
e2e/.cache/
playwright-report/
test-results/
pw-results.xml

# Vitest v8 coverage output (see vitest.unit.config.ts; reporting only)
coverage/

# Security scan output (ccsec-detection / triage / patch skills write here)
results/

# OTA signing — never commit private key material
ota-private*.pem
ota-public*.pem
*.signing.key
.claude/worktrees/
