#!/bin/sh
# kai — terminal client for the Kai desktop app.
#
# Runs the CLI inside the app's OWN signed Electron binary (via `--kai-cli`), so
# no separate Node runtime is needed and the security fuses stay locked. The
# binary is exec'd DIRECTLY (not via `open`) so it inherits this terminal's
# stdin/stdout/tty and the Ink TUI can render.
#
# Installed on PATH by electron-builder's afterPack (macOS) — typically as a
# symlink from /usr/local/bin/kai to Kai.app/Contents/Resources/bin/kai. The
# PRIMARY resolution derives the app binary from THIS script's own real path
# (../../MacOS/Kai), so the CLI always runs the exact bundle it shipped in — no
# trusting a same-bundle-id app that Spotlight happens to find first.

set -eu

# Resolve the real path of a file, following symlinks, without readlink -f
# (absent on stock macOS). Pure-sh loop.
resolve_real_path() {
  _p=$1
  # cd into the dir + basename loop to canonicalize through symlinks.
  while [ -L "$_p" ]; do
    _dir=$(cd -P "$(dirname "$_p")" 2>/dev/null && pwd) || return 1
    _link=$(ls -ld "$_p" | sed -e 's/^.* -> //')
    case "$_link" in
      /*) _p=$_link ;;
      *) _p=$_dir/$_link ;;
    esac
  done
  _dir=$(cd -P "$(dirname "$_p")" 2>/dev/null && pwd) || return 1
  printf '%s\n' "$_dir/$(basename "$_p")"
}

find_binary() {
  # 1. Explicit override.
  if [ -n "${KAI_APP_BINARY:-}" ] && [ -x "${KAI_APP_BINARY}" ]; then
    printf '%s\n' "${KAI_APP_BINARY}"
    return 0
  fi

  case "$(uname -s)" in
    Darwin)
      # 2. PRIMARY: derive the app binary from this script's own location.
      # Shipped at Kai.app/Contents/Resources/bin/kai → ../../MacOS/Kai. This is
      # the signed binary of the very bundle this shim belongs to, so a stale/
      # moved/malicious same-bundle-id app can't hijack the CLI.
      _self=$(resolve_real_path "$0" 2>/dev/null || true)
      if [ -n "$_self" ]; then
        # `|| true` so a failed cd (not inside a bundle) doesn't abort under
        # `set -e` and skip the fixed-location/Spotlight fallbacks below.
        _macos_dir=$(cd "$(dirname "$_self")/../../MacOS" 2>/dev/null && pwd || true)
        if [ -n "$_macos_dir" ] && [ -x "$_macos_dir/Kai" ]; then
          printf '%s\n' "$_macos_dir/Kai"
          return 0
        fi
      fi
      # 3. Fixed install locations.
      for app in \
        "/Applications/Kai.app" \
        "$HOME/Applications/Kai.app"; do
        if [ -x "$app/Contents/MacOS/Kai" ]; then
          printf '%s\n' "$app/Contents/MacOS/Kai"
          return 0
        fi
      done
      # 4. Spotlight, last resort. Only trust a hit whose code signature is
      # valid AND whose bundle id matches — a same-bundle-id app that fails
      # signature verification (moved/tampered/mounted) is NOT run.
      mdfind_path=$(mdfind "kMDItemCFBundleIdentifier == 'com.kai.desktop'" 2>/dev/null | head -n1 || true)
      if [ -n "$mdfind_path" ] && [ -x "$mdfind_path/Contents/MacOS/Kai" ]; then
        if codesign --verify --deep --strict "$mdfind_path" >/dev/null 2>&1; then
          printf '%s\n' "$mdfind_path/Contents/MacOS/Kai"
          return 0
        fi
      fi
      ;;
    Linux)
      # PRIMARY: derive the app binary from this script's own real path, so a
      # symlinked shim (e.g. ~/.local/bin/kai → .../resources/bin/kai) or an
      # AppImage mount at a random path still finds its app. The launcher is
      # shipped at <appRoot>/resources/bin/kai; the ELF binary is <appRoot>/kai.
      _self=$(resolve_real_path "$0" 2>/dev/null || true)
      if [ -n "$_self" ]; then
        _selfdir=$(cd -P "$(dirname "$_self")" 2>/dev/null && pwd || true)
        if [ -n "$_selfdir" ]; then
          for rel in "../../kai" "../kai"; do
            _cand=$(cd -P "$_selfdir" 2>/dev/null && cd -P "$(dirname "$rel")" 2>/dev/null && pwd || true)
            if [ -n "$_cand" ] && [ -x "$_cand/$(basename "$rel")" ]; then
              printf '%s\n' "$_cand/$(basename "$rel")"
              return 0
            fi
          done
        fi
      fi
      # Fixed install locations (deb / manual).
      for cand in /opt/Kai/kai /usr/lib/kai/kai "$HOME/.local/lib/kai/kai"; do
        if [ -x "$cand" ]; then printf '%s\n' "$cand"; return 0; fi
      done
      ;;
  esac
  return 1
}

BIN=$(find_binary) || {
  echo "kai: could not locate the Kai app binary." >&2
  echo "     Install Kai, or set KAI_APP_BINARY to its executable path." >&2
  exit 127
}

# Defensively filter the historical SQLite warning when this launcher is pointed
# at an older app binary via KAI_APP_BINARY. Current builds keep Undici external
# and fail the build if node:sqlite is eagerly imported, so they do not emit it.
# stdout (the Ink TUI) and stdin (the TTY) are untouched; the child's real exit
# code is preserved via a temp file. If grep/mktemp are unavailable, fall back to
# a plain exec so the CLI always runs.
if command -v grep >/dev/null 2>&1 && command -v mktemp >/dev/null 2>&1; then
  __kai_status=$(mktemp) || exec "$BIN" --kai-cli "$@"
  # fd3 = the terminal's stdout. Child stdout → fd1 (terminal); child stderr →
  # the pipe → grep → the terminal's stderr. Capture the child's real status into
  # a temp file (a pipeline's own $? would be grep's). `if ...; then ... else`
  # captures the exit code WITHOUT tripping `set -e` on a non-zero child, and the
  # grep gets `|| true` because grep exits 1 when it filters out ALL input.
  { { if "$BIN" --kai-cli "$@"; then echo 0 >"$__kai_status"; else echo $? >"$__kai_status"; fi; } 2>&1 1>&3 \
      | { grep -vE 'ExperimentalWarning: SQLite is an experimental feature|--trace-warnings' >&2 || true; }; } 3>&1
  __kai_code=$(cat "$__kai_status" 2>/dev/null); rm -f "$__kai_status"
  exit "${__kai_code:-0}"
fi
exec "$BIN" --kai-cli "$@"
