{
  "name": "kai",
  "productName": "Kai",
  "version": "1.0.183",
  "description": "Kai - Local AI Assistant",
  "main": "./out/main/index.js",
  "bin": {
    "kai": "./bin/kai"
  },
  "desktopName": "com.kai.desktop.desktop",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/maybe-compile-swift.mjs && electron-vite dev",
    "build": "node scripts/maybe-compile-swift.mjs && node scripts/build-mermaid-runtime.mjs && electron-vite build",
    "generate:mermaid": "node scripts/build-mermaid-runtime.mjs",
    "kai": "node out/main/cli.js",
    "kai:build": "electron-vite build && node out/main/cli.js",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "rebuild": "electron-builder install-app-deps",
    "compile:swift": "bash scripts/compile-swift-helper.sh",
    "coordinate-test": "tsx scripts/coordinate-test.ts",
    "generate:builder": "tsx scripts/generate-builder-config.ts",
    "generate:dmg-bg": "tsx scripts/generate-dmg-background.ts",
    "build:mac": "pnpm generate:dmg-bg && pnpm build && pnpm generate:builder && pnpm assert:update-verification && electron-builder --mac --publish never --config",
    "build:win": "pnpm build && pnpm generate:builder && pnpm assert:update-verification && electron-builder --win --publish never --config",
    "build:linux": "pnpm build && pnpm generate:builder && electron-builder --linux --publish never --config",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:real": "vitest run --config vitest.integration.config.ts electron/__tests__/integration-real/",
    "test:evals": "tsx electron/__tests__/evals/run-evals.ts",
    "test:coverage": "vitest --coverage --run -c vitest.unit.config.ts",
    "fixtures:gen": "tsx electron/__tests__/__fixtures__/generate.ts",
    "test:fixtures:verify": "tsx scripts/verify-fixtures.ts",
    "compare:fixture-shapes": "tsx scripts/compare-fixture-shapes.ts",
    "verify:fuses": "tsx scripts/verify-fuses.ts",
    "check:lockfile-registry": "node scripts/check-lockfile-registry.mjs",
    "assert:update-verification": "tsx scripts/assert-update-verification.ts",
    "test:ipc-seam:linux": "playwright test --config playwright.config.ts",
    "validate:linux-cli": "docker run --rm -v \"$PWD/bin:/work/bin:ro\" -v \"$PWD/scripts/validate-linux-launcher.sh:/validate.sh:ro\" debian:stable-slim sh /validate.sh",
    "smoke:cli:linux": "sh scripts/smoke-cli-linux.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@mastra/evals": "^1.2.2",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/semver": "^7.7.1",
    "@types/shell-quote": "^1.7.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "fast-check": "^4.0.0",
    "husky": "^9.1.0",
    "ink-testing-library": "4.0.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.0",
    "msw": "^2.6.0",
    "sharp": "0.34.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "undici": "^8.3.0",
    "vite": "^7.3.2",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.93",
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/azure": "^3.0.53",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/provider-utils": "^4.0.23",
    "@anthropic-ai/claude-agent-sdk": "0.2.139",
    "@assistant-ui/react": "0.12.24",
    "@assistant-ui/react-markdown": "0.12.8",
    "@aws-sdk/credential-provider-node": "^3.972.30",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@libsql/client": "0.17.2",
    "@lydell/node-pty": "^1.1.0",
    "@mastra/ai-sdk": "^1.4.0",
    "@mastra/core": "^1.25.0",
    "@mastra/libsql": "^1.8.1",
    "@mastra/memory": "^1.15.1",
    "@mastra/schema-compat": "^1.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.130.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.158",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "cli-highlight": "^2.1.11",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.6",
    "dotenv": "^17.4.1",
    "electron-updater": "6.8.3",
    "esbuild": "^0.28.0",
    "graphql": "^16.13.2",
    "highlight.js": "^11.11.1",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-beautify": "^1.15.4",
    "json5": "^2.2.3",
    "jsonrepair": "^3.13.3",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.4.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.49.0",
    "node-forge": "^1.4.0",
    "openai": "^6.34.0",
    "picomatch": "^4.0.4",
    "prettier": "^3.8.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-shiki": "^0.9.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.2",
    "semver": "^7.7.4",
    "shell-quote": "^1.8.1",
    "tailwind-merge": "^3.5.0",
    "tiktoken": "^1.0.22",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.20.0",
    "xml-formatter": "^3.7.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "active-win": "^9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "supportedArchitectures": {
      "cpu": [
        "x64",
        "arm64"
      ]
    },
    "onlyBuiltDependencies": [
      "@nut-tree-fork/libnut",
      "active-win",
      "electron",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "@assistant-ui/core": "0.1.13",
      "@assistant-ui/store": "0.2.6",
      "@assistant-ui/tap": "0.5.7",
      "picomatch": ">=4.0.4",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "fast-xml-parser@>=5.0.0 <5.5.6": ">=5.5.6",
      "@xmldom/xmldom": "~0.8.12"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "pnpm-lock.yaml": [
      "node scripts/check-lockfile-registry.mjs"
    ]
  }
}
